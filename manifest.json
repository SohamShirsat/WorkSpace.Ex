{
  "manifest_version": 3,
  "name": "WorkSpace",
  "version": "1.0.0",
  "description": "Focus-mode tab & workspace manager",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "windows",
    "scripting",
    "idle",
    "alarms",
    "contextMenus"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "settings.html",
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+W",
        "mac": "Command+Shift+W"
      }
    },
    "switch-workspace": {
      "description": "Open WorkSpace switcher"
    },
    "focus-mode-toggle": {
      "description": "Toggle Focus Mode"
    }
  }
}
